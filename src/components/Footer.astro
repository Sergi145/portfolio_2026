<footer class="site-footer" role="contentinfo">
  <div class="container">
    <nav class="footer__social" aria-label="Redes sociales">
      {socialLinks.map(({ href, label, icon }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={label}
          set:html={icon}
        />
      ))}
    </nav>
    <p class="footer__copy">© 2026 Sergi Picazo. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  /* =============================================
     BLOCK: site-footer
  ============================================= */
  .site-footer {
    background: var(--color-text);
    color: rgba(245, 244, 240, 0.5);
    padding-block: var(--space-md);
    text-align: center;
    font-size: 0.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ELEMENT: footer__social */
  .footer__social {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }
  .footer__social a {
    color: rgba(245, 244, 240, 0.5);
    text-decoration: none;
    display: flex;
    transition: color var(--transition);
  }
  .footer__social a:hover, .footer__social a:focus { color: #f5f4f0; }
  .footer__social a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 3px;
  }

  /* ELEMENT: footer__copy */
  .footer__copy { color: white; }
</style>
