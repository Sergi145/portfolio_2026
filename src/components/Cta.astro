---
// src/components/Cta.astro
---

<section class="cta" id="contacto" aria-labelledby="cta-title">
  <div class="container">
    <h2 class="cta__title" id="cta-title">
      ¿Quieres contactar<br />
      <span class="cta__title-highlight">conmigo</span>?
    </h2>
    <div class="cta__actions">
      <a
        href="mailto:hola@alejandroruiz.dev"
        class="btn btn--primary"
      >
        Escribirme ahora <span class="visually-hidden">por correo electrónico</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round"
          aria-hidden="true" focusable="false">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
      <a
        href="https://linkedin.com/in/alejandroruiz"
        class="btn btn--outline-light"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Ver perfil de LinkedIn (abre en nueva pestaña)"
      >
        LinkedIn
      </a>
    </div>
  </div>
</section>

<style>
  /* =============================================
     BLOCK: cta
  ============================================= */
  .cta {
    background: var(--color-text);
    color: #f5f4f0;
    padding-block: var(--space-2xl);
    text-align: center;
  }

  /* ELEMENT: cta__title */
  .cta__title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-sm);
  }

  /* ELEMENT: cta__title-highlight */
  .cta__title-highlight { color: var(--color-accent); }

  /* ELEMENT: cta__desc */
  .cta__desc {
    font-size: 1.05rem;
    color: rgba(245, 244, 240, 0.65);
    max-width: 480px;
    margin-inline: auto;
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }

  /* ELEMENT: cta__actions */
  .cta__actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
